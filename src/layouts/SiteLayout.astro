---
import '../styles/global.css'

interface Props {
  title: string
  description?: string
  canonicalPath?: string
  ogImage?: string
  ogType?: 'website' | 'article'
  noIndex?: boolean
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>
}

const {
  title,
  description = 'ERP Search: independent ERP guidance, comparisons, and implementation insights for small and medium businesses',
  canonicalPath,
  ogImage,
  ogType = 'website',
  noIndex = false,
  jsonLd,
} = Astro.props

const configuredSiteUrl = import.meta.env.PUBLIC_SITE_URL || Astro.site?.toString() || 'http://localhost:4321'
const siteOrigin = configuredSiteUrl.endsWith('/') ? configuredSiteUrl.slice(0, -1) : configuredSiteUrl
const canonicalUrl = new URL(canonicalPath || Astro.url.pathname, `${siteOrigin}/`).toString()
const ogImageUrl = ogImage ? new URL(ogImage, `${siteOrigin}/`).toString() : new URL('/hero-erp-brief.svg', `${siteOrigin}/`).toString()
const robotsContent = noIndex ? 'noindex,nofollow' : 'index,follow,max-image-preview:large'
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ERP Search',
  url: `${siteOrigin}/`,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteOrigin}/guides/`,
    'query-input': 'required name=query',
  },
}
const jsonLdPayload = Array.isArray(jsonLd) ? [websiteSchema, ...jsonLd] : jsonLd ? [websiteSchema, jsonLd] : [websiteSchema]
const ga4Id = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID
const clarityId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:site_name" content="ERP Search" />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="theme-color" content="#0e5a4f" />
    <link rel="icon" type="image/svg+xml" href="/logo-navigator-mark.svg" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLdPayload)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    {ga4Id && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}></script>
        <script is:inline define:vars={{ga4Id}}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          window.gtag = gtag;
          gtag('js', new Date());
          gtag('config', ga4Id, {
            anonymize_ip: true,
            send_page_view: true,
          });
        </script>
      </>
    )}
    {clarityId && (
      <script is:inline define:vars={{clarityId}}>
        (function(c,l,a,r,i,t,y){
          c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        })(window, document, "clarity", "script", clarityId);
      </script>
    )}
  </head>
  <body>
    <div class="compliance-strip" role="note" aria-label="Privacy and disclosure notice">
      <div class="container compliance-row">
        <p>
          We use analytics (Google Analytics and Microsoft Clarity) to improve content and user experience. Partner
          introductions may be compensated.
        </p>
        <p><a href="/privacy/">Privacy</a> · <a href="/disclosure/">Disclosure</a></p>
      </div>
    </div>
    <header class="site-header">
      <div class="container header-row">
        <a class="brand" href="/">
          <img class="mark" src="/logo-navigator-mark.svg" alt="ERP Search" />
          <span>
            <strong>ERP Search</strong>
            <small>Independent ERP guidance for growing businesses</small>
          </span>
        </a>
        <nav class="nav">
          <a href="/">Home</a>
          <a href="/guides/">Guides</a>
          <a href="/compare/">Compare</a>
          <a href="/blog/">Blog</a>
        </nav>
        <div class="site-search" data-site-search>
          <label class="site-search-label" for="site-search-input">Search content</label>
          <input
            id="site-search-input"
            class="site-search-input"
            type="search"
            placeholder="Search guides, comparisons, blogs..."
            autocomplete="off"
            data-search-input
          />
          <div class="site-search-results" data-search-results hidden></div>
        </div>
      </div>
    </header>
    <main class="container page">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container footer-row">
        <div>
          <p class="footer-title">ERP Search</p>
          <p>Independent ERP buyer education and partner-fit guidance for small and medium businesses.</p>
        </div>
        <p>
          <a href="/guides/">Guides</a> · <a href="/compare/">Compare</a> · <a href="/blog/">Blog</a> ·
          <a href="/privacy/">Privacy</a> · <a href="/disclosure/">Disclosure</a>
        </p>
      </div>
    </footer>
    <script is:inline>
      {`
        (() => {
          const root = document.querySelector('[data-site-search]');
          if (!root) return;

          const input = root.querySelector('[data-search-input]');
          const results = root.querySelector('[data-search-results]');
          if (!input || !results) return;

          let index = [];
          let loaded = false;
          let loading = false;
          let activeIndex = -1;

          const getHits = () => Array.from(results.querySelectorAll('.site-search-hit'));

          const updateActiveHit = () => {
            const hits = getHits();
            hits.forEach((hit, index) => {
              const isActive = index === activeIndex;
              hit.classList.toggle('is-active', isActive);
              hit.setAttribute('aria-selected', isActive ? 'true' : 'false');
            });
          };

          const resetActiveHit = () => {
            activeIndex = -1;
            updateActiveHit();
          };

          const formatDate = (value) => {
            try {
              return new Date(value).toLocaleDateString('en-AU', {
                day: 'numeric',
                month: 'short',
                year: 'numeric',
              });
            } catch {
              return '';
            }
          };

          const escapeHtml = (value) =>
            String(value || '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;')
              .replace(/"/g, '&quot;')
              .replace(/'/g, '&#39;');

          const scoreItem = (item, query) => {
            const title = item.title.toLowerCase();
            const text = item.searchableText.toLowerCase();
            let score = 0;
            if (title.includes(query)) score += 8;
            if (text.includes(query)) score += 4;
            for (const term of query.split(/\\s+/)) {
              if (!term) continue;
              if (title.includes(term)) score += 3;
              if (text.includes(term)) score += 1;
            }
            return score;
          };

          const renderResults = (items, query) => {
            if (!query.trim()) {
              results.hidden = true;
              results.innerHTML = '';
              resetActiveHit();
              return;
            }

            if (!items.length) {
              results.hidden = false;
              results.innerHTML = '<p class="site-search-empty">No matching content yet.</p>';
              resetActiveHit();
              return;
            }

            results.hidden = false;
            results.innerHTML = items
              .map((item) => {
                const meta = [item.section, item.kind, item.readTime + ' min read', formatDate(item.publishedAt)].filter(Boolean).join(' · ');
                return \`
                  <a class="site-search-hit" href="\${item.href}" aria-selected="false">
                    <span class="site-search-hit-section">\${escapeHtml(item.section)}</span>
                    <strong>\${escapeHtml(item.title)}</strong>
                    <span class="site-search-hit-meta">\${escapeHtml(meta)}</span>
                    <span class="site-search-hit-excerpt">\${escapeHtml(item.excerpt)}</span>
                  </a>
                \`;
              })
              .join('');
            resetActiveHit();
          };

          const loadIndex = async () => {
            if (loaded || loading) return;
            loading = true;
            try {
              const response = await fetch('/search-index.json');
              if (!response.ok) return;
              index = await response.json();
              loaded = true;
            } catch {}
            loading = false;
          };

          input.addEventListener('focus', () => {
            loadIndex();
          });

          input.addEventListener('input', async (event) => {
            const query = event.target.value.trim().toLowerCase();
            await loadIndex();
            const matches = index
              .map((item) => ({item, score: scoreItem(item, query)}))
              .filter((entry) => entry.score > 0)
              .sort((a, b) => b.score - a.score)
              .slice(0, 8)
              .map((entry) => entry.item);
            renderResults(matches, query);
          });

          document.addEventListener('click', (event) => {
            if (!root.contains(event.target)) {
              results.hidden = true;
              resetActiveHit();
            }
          });

          input.addEventListener('keydown', (event) => {
            const hits = getHits();

            if (event.key === 'ArrowDown' && hits.length) {
              event.preventDefault();
              activeIndex = activeIndex < hits.length - 1 ? activeIndex + 1 : 0;
              updateActiveHit();
              hits[activeIndex].scrollIntoView({block: 'nearest'});
              return;
            }

            if (event.key === 'ArrowUp' && hits.length) {
              event.preventDefault();
              activeIndex = activeIndex > 0 ? activeIndex - 1 : hits.length - 1;
              updateActiveHit();
              hits[activeIndex].scrollIntoView({block: 'nearest'});
              return;
            }

            if (event.key === 'Enter' && hits.length) {
              event.preventDefault();
              const targetIndex = activeIndex >= 0 ? activeIndex : 0;
              const href = hits[targetIndex].getAttribute('href');
              if (href) {
                window.location.href = href;
              }
              return;
            }

            if (event.key === 'Escape') {
              results.hidden = true;
              resetActiveHit();
              input.blur();
            }
          });
        })();
      `}
    </script>
  </body>
</html>
