---
import SiteLayout from '../../layouts/SiteLayout.astro'
import EditorialMarker from '../../components/EditorialMarker.astro'
import PageVisual from '../../components/PageVisual.astro'
import {pageVisuals} from '../../lib/pageVisuals'
import {estimateReadTimeMinutes, formatPublishDate, sortByPublishedDateDesc} from '../../lib/contentMeta'
import {editorialTeamName} from '../../lib/editorial'
import {buildBreadcrumbSchema, getListPageMeta} from '../../lib/seo'
import {getPosts} from '../../lib/sanity'

const posts = sortByPublishedDateDesc(await getPosts())
const meta = getListPageMeta('blog')
const breadcrumbSchema = buildBreadcrumbSchema([
  {name: 'Home', path: '/'},
  {name: 'Blog', path: '/blog/'},
])
---

<SiteLayout
  title={`${meta.metaTitle} | ERP Search`}
  description={meta.metaDescription}
  canonicalPath="/blog/"
  ogImage={pageVisuals.blog.src}
  jsonLd={breadcrumbSchema}
>
  <div class="page-kicker">
    <p class="eyebrow">Blog</p>
    <p class="editorial-toolbar">{posts.length} published post{posts.length === 1 ? '' : 's'}</p>
  </div>
  <h1 class="page-title">ERP Blog for SMBs</h1>
  <p class="section-subtle">Buyer guidance, release notes, and practical ERP insights for finance, operations, and IT leaders.</p>
  <PageVisual src={pageVisuals.blog.src} alt={pageVisuals.blog.alt} caption="Market context and execution patterns that matter during ERP projects." />
  <div class="editorial-list section">
    {posts.map((post) => (
      <article class="editorial-item">
        <div class="editorial-topline">
          <EditorialMarker variant="post" category={post.category} />
          <p class="eyebrow">{post.category}</p>
        </div>
        <h2><a href={`/blog/${post.slug}/`}>{post.title}</a></h2>
        <div class="meta-row">
          <p class="meta">Published {formatPublishDate(post.publishedAt)}</p>
          <span class="meta-pill">{estimateReadTimeMinutes(post)} min read</span>
          <span class="meta-pill">Reviewed by {editorialTeamName}</span>
        </div>
        <p>{post.excerpt}</p>
      </article>
    ))}
  </div>
</SiteLayout>
