---
import SiteLayout from '../../layouts/SiteLayout.astro'
import PageVisual from '../../components/PageVisual.astro'
import {getBlogVisual} from '../../lib/pageVisuals'
import {blocksToPlainParagraphs, blocksToRichContent} from '../../lib/portableText'
import {estimateReadTimeMinutes, formatPublishDate} from '../../lib/contentMeta'
import {getRelatedBlogLinks} from '../../lib/relatedContent'
import {buildBreadcrumbSchema, extractFaqSchema, getDocMeta} from '../../lib/seo'
import {getPostBySlug, getPosts} from '../../lib/sanity'

export async function getStaticPaths() {
  const posts = await getPosts()
  return posts.map((post) => ({params: {slug: post.slug}}))
}

const {slug} = Astro.params
const post = slug ? await getPostBySlug(slug) : undefined

if (!post) {
  return Astro.redirect('/blog/')
}

const paragraphs = blocksToPlainParagraphs(post.body)
const content = blocksToRichContent(post.body)
const readTime = estimateReadTimeMinutes(post)
const canonicalPath = `/blog/${post.slug}/`
const visual = getBlogVisual(post.slug)
const relatedLinks = getRelatedBlogLinks(post.slug)
const seoMeta = getDocMeta(post)
const breadcrumbSchema = buildBreadcrumbSchema([
  {name: 'Home', path: '/'},
  {name: 'Blog', path: '/blog/'},
  {name: post.title, path: canonicalPath},
])
const faqSchema = extractFaqSchema(post.body)
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: seoMeta.metaTitle,
  description: seoMeta.metaDescription,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  image: [visual.src],
  articleSection: post.category || 'ERP insights',
  mainEntityOfPage: {'@type': 'WebPage', '@id': canonicalPath},
}
const pageSchemas = faqSchema ? [breadcrumbSchema, articleSchema, faqSchema] : [breadcrumbSchema, articleSchema]
---

<SiteLayout
  title={`${seoMeta.metaTitle} | ERP Search`}
  description={seoMeta.metaDescription}
  canonicalPath={canonicalPath}
  ogImage={visual.src}
  ogType="article"
  noIndex={Boolean(post.seo?.noIndex)}
  jsonLd={pageSchemas}
>
  <div class="doc-layout">
    <article class="doc-main">
      <p class="eyebrow">{post.category}</p>
      <h1>{post.title}</h1>
      <div class="meta-row">
        <p class="meta">Published {formatPublishDate(post.publishedAt)}</p>
        <span class="meta-pill">{readTime} min read</span>
        {post.updatedAt && <span class="meta-pill">Updated {formatPublishDate(post.updatedAt)}</span>}
      </div>
      <PageVisual
        src={visual.src}
        alt={visual.alt}
        caption={visual.caption}
      />
      <section class="summary-box" aria-label="Post summary">
        <h2>Editorial context</h2>
        <dl>
          <dt>Category</dt>
          <dd>{post.category}</dd>
          <dt>Role</dt>
          <dd>Top-of-funnel trust + newsletter content</dd>
          <dt>Next step</dt>
          <dd>Link to related guide or comparison page</dd>
        </dl>
      </section>
      <p class="lead">{post.excerpt}</p>
      {content.length ? (
        content.map((block) =>
          block.type === 'heading' ? (
            <h2>{block.text}</h2>
          ) : block.type === 'list' ? (
            <ul>
              {block.items.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          ) : (
            <p>{block.text}</p>
          ),
        )
      ) : (
        <p class="empty">No content body yet.</p>
      )}
    </article>
    <aside class="doc-side">
      <section class="card">
        <h2>Content type</h2>
        <p>Use blog posts for news, commentary, and promotion of long-form guides/comparisons.</p>
        <p><a class="link-arrow" href="/guides/">Link readers into guides →</a></p>
      </section>
      <section class="card">
        <h2>How we evaluate ERP topics</h2>
        <p>Read how ERP Search approaches buyer guidance, software comparisons, and implementation advice.</p>
        <p><a class="link-arrow" href="/about/">See our methodology →</a></p>
      </section>
      {relatedLinks.length ? (
        <section class="card">
          <h2>Related reading</h2>
          <ul>
            {relatedLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      ) : null}
    </aside>
  </div>
</SiteLayout>
