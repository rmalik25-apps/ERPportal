---
import SiteLayout from '../layouts/SiteLayout.astro'
import PageVisual from '../components/PageVisual.astro'
import {pageVisuals} from '../lib/pageVisuals'
---

<SiteLayout
  title="Privacy Notice | ERP Navigator"
  description="Privacy notice covering analytics usage, inquiry data handling, and partner introduction workflows."
  canonicalPath="/privacy/"
  ogImage={pageVisuals.privacy.src}
>
  <div class="doc-layout">
    <article class="doc-main">
      <p class="eyebrow">Privacy</p>
      <h1>Privacy notice</h1>
      <PageVisual
        src={pageVisuals.privacy.src}
        alt={pageVisuals.privacy.alt}
        caption="How we collect and use data for analytics and partner introductions."
      />
      <p class="lead">
        ERP Navigator uses analytics and form submissions to improve content quality and respond to ERP guidance
        requests. This page is a starter notice and should be reviewed with legal counsel before production launch.
      </p>

      <p>
        We may collect information you submit through forms, including contact details, company information, current ERP
        system, project timelines, and implementation priorities. We use this information to provide ERP guidance and,
        when requested, facilitate partner introductions.
      </p>
      <p>
        We use analytics tools such as Google Analytics 4 and Microsoft Clarity to understand site traffic, page usage,
        and engagement behaviour. This helps us improve content, navigation, and conversion flows.
      </p>
      <p>
        If you request partner introductions, relevant project details may be shared with selected consulting partners
        to support that request. Partner introductions may be compensated.
      </p>
      <p>
        Before launch, add your legal entity name, contact details, retention periods, cookie consent policy, and
        region-specific language (for example UK/EU requirements) as applicable.
      </p>
    </article>
    <aside class="doc-side">
      <section class="card">
        <h2>Before launch checklist</h2>
        <ul>
          <li>Add legal business name and contact email</li>
          <li>Document cookie consent requirements by region</li>
          <li>List your CRM, email, and analytics processors</li>
          <li>Review with legal counsel</li>
        </ul>
      </section>
    </aside>
  </div>
</SiteLayout>
