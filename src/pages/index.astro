---
import SiteLayout from '../layouts/SiteLayout.astro'
import {estimateReadTimeMinutes, formatPublishDate, sortByPublishedDateDesc} from '../lib/contentMeta'
import {getComparisons, getGuides, getPosts, sanityConfigured} from '../lib/sanity'
import {getListPageMeta} from '../lib/seo'

const [guides, comparisons, posts] = await Promise.all([getGuides(), getComparisons(), getPosts()])
const latestGuides = sortByPublishedDateDesc(guides).slice(0, 2)
const latestComparisons = sortByPublishedDateDesc(comparisons).slice(0, 2)
const latestPosts = sortByPublishedDateDesc(posts).slice(0, 2)
const featuredGuides = guides.slice(0, 2)
const featuredPosts = posts.slice(0, 4)
const featuredComparison = comparisons[0]
const navGuide = guides.find((guide) => guide.slug.includes('nav'))
const partnerGuide = guides.find((guide) => guide.slug.includes('partner'))
const assessmentEndpoint = import.meta.env.PUBLIC_ASSESSMENT_ENDPOINT || '/api/assessment'
const newsletterEndpoint = import.meta.env.PUBLIC_NEWSLETTER_ENDPOINT || '/api/newsletter'
const pollEndpoint = import.meta.env.PUBLIC_POLL_ENDPOINT || (import.meta.env.DEV ? 'https://erpsearch.com.au/api/poll' : '/api/poll')
const pollBrandAssets = {
  'Business Central / NAV': '/brands/business-central-nav.svg',
  NetSuite: '/brands/netsuite.svg',
  'MYOB Acumatica': '/brands/myob-acumatica.svg',
  Odoo: '/brands/odoo.svg',
  'Sage Intacct': '/brands/sage-intacct.svg',
  'SAP / other legacy ERP': '/brands/sap-legacy.svg',
  'Spreadsheets / none yet': '/brands/spreadsheets.svg',
}
const homeMeta = getListPageMeta('home')
---

<SiteLayout
  title={homeMeta.metaTitle}
  description={homeMeta.metaDescription}
  canonicalPath="/"
  ogImage="/hero-erp-brief.svg"
>
  <section class="hero">
    <div class="hero-shell">
      <div>
        <p class="eyebrow">Independent ERP Buyer Education + Lead Generation</p>
        <h1>Your one-stop hub for ERP decisions in growing businesses</h1>
        <p>
          We help finance, operations, and IT leaders make confident ERP decisions with practical guidance on
          selection, implementation, upgrades, and ongoing improvement.
        </p>
        <div class="home-actions">
          <a class="btn btn-primary" href="#get-guidance">Get ERP Recommendations</a>
          <a class="btn btn-secondary" href="/compare/">Browse Comparisons</a>
        </div>
        <ul class="chip-row" aria-label="Covered ERP ecosystems">
          <li><a href="/search/?q=best%20erp%20smb">Best ERP for SMBs</a></li>
          <li><a href="/search/?q=erp%20comparison">ERP comparisons</a></li>
          <li><a href="/search/?q=erp%20implementation">ERP implementation guides</a></li>
          <li><a href="/search/?q=erp%20rfp">ERP RFP guides</a></li>
          <li><a href="/search/?q=implementation%20partner">Choosing an ERP partner</a></li>
          <li><a href="/search/?q=business%20central">Business Central</a></li>
          <li><a href="/search/?q=netsuite">NetSuite</a></li>
          <li><a href="/search/?q=odoo">Odoo</a></li>
        </ul>
        <p class="banner">
          {sanityConfigured
            ? 'Independent buyer guidance with transparent disclosure. Use this site to shortlist options before vendor demos.'
            : 'Independent buyer guidance with transparent partner-introduction disclosure. Content is being expanded and refreshed regularly.'}
        </p>
        <div class="hero-utility-grid">
          <article class="hero-utility-card hero-utility-card-poll">
            <p class="hero-utility-label">Quick poll</p>
            <h2>Which ERP are you using today?</h2>
            <form class="hero-poll" data-hero-poll>
              <div class="hero-poll-inputs" data-hero-poll-inputs>
                <div class="hero-poll-options">
                  <label><input type="radio" name="currentErp" value="Business Central / NAV" /> <img class="hero-brand-logo" src={pollBrandAssets['Business Central / NAV']} alt="Business Central / NAV" /><span>Business Central / NAV</span></label>
                  <label><input type="radio" name="currentErp" value="NetSuite" /> <img class="hero-brand-logo" src={pollBrandAssets['NetSuite']} alt="NetSuite" /><span>NetSuite</span></label>
                  <label><input type="radio" name="currentErp" value="MYOB Acumatica" /> <img class="hero-brand-logo" src={pollBrandAssets['MYOB Acumatica']} alt="MYOB Acumatica" /><span>MYOB Acumatica</span></label>
                  <label><input type="radio" name="currentErp" value="Odoo" /> <img class="hero-brand-logo" src={pollBrandAssets['Odoo']} alt="Odoo" /><span>Odoo</span></label>
                  <label><input type="radio" name="currentErp" value="Sage Intacct" /> <img class="hero-brand-logo" src={pollBrandAssets['Sage Intacct']} alt="Sage Intacct" /><span>Sage Intacct</span></label>
                  <label><input type="radio" name="currentErp" value="SAP / other legacy ERP" /> <img class="hero-brand-logo" src={pollBrandAssets['SAP / other legacy ERP']} alt="SAP / other legacy ERP" /><span>SAP / other legacy ERP</span></label>
                  <label><input type="radio" name="currentErp" value="Spreadsheets / none yet" /> <img class="hero-brand-logo" src={pollBrandAssets['Spreadsheets / none yet']} alt="Spreadsheets / none yet" /><span>Spreadsheets / none yet</span></label>
                </div>
                <div class="hero-poll-actions">
                  <button class="btn btn-secondary btn-small" data-hero-poll-submit type="submit">Vote</button>
                  <p class="hero-poll-status" data-hero-poll-input-status role="status" aria-live="polite"></p>
                </div>
              </div>
              <div class="hero-poll-summary" data-hero-poll-summary hidden>
                <div class="hero-poll-summary-bar">
                  <p class="hero-poll-status" data-hero-poll-summary-status role="status" aria-live="polite"></p>
                  <button class="hero-poll-change" data-hero-poll-change type="button">Change my vote</button>
                </div>
                <p class="hero-poll-leader" data-hero-poll-leader hidden></p>
                <div class="hero-poll-results" data-hero-poll-results hidden></div>
              </div>
            </form>
          </article>
        </div>
      </div>
      <aside class="hero-panel">
        <figure class="hero-visual">
          <div class="hero-collage" aria-hidden="true">
            <img
              class="hero-collage-main"
              src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?auto=format&fit=crop&w=1400&q=80"
              alt=""
            />
            <img
              class="hero-collage-inset"
              src="https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=900&q=80"
              alt=""
            />
            <div class="hero-collage-label hero-collage-label-a">Operations reality</div>
            <div class="hero-collage-label hero-collage-label-b">Executive planning</div>
          </div>
          <figcaption>
            Make better ERP decisions before vendor demos, with guidance on product fit, delivery risk, and next steps.
          </figcaption>
        </figure>
        <h2>Start your ERP shortlist here</h2>
        <p>Tell us a little about your project and we can follow up with a practical shortlist direction.</p>
        <form class="home-form hero-form js-lead-form" data-endpoint={assessmentEndpoint} novalidate>
          <label>
            Work email
            <input type="email" name="email" autocomplete="email" placeholder="name@company.com" required />
          </label>
          <div class="phone-row">
            <label>
              Country code
              <select name="phoneCountryCode" required>
                <option value="+61" selected>Australia (+61)</option>
                <option value="+64">New Zealand (+64)</option>
                <option value="+44">United Kingdom (+44)</option>
                <option value="+1">United States/Canada (+1)</option>
                <option value="+65">Singapore (+65)</option>
                <option value="+91">India (+91)</option>
              </select>
            </label>
            <label>
              Phone number
              <input type="tel" name="phoneNumber" autocomplete="tel-national" inputmode="tel" placeholder="0412 345 678" required />
            </label>
          </div>
          <label>
            Company size
            <select name="companySize" required>
              <option value="">Select company size</option>
              <option>50-100 employees</option>
              <option>101-500 employees</option>
              <option>501-2,500 employees</option>
              <option>2,500+ employees</option>
            </select>
          </label>
          <label>
            Project type
            <select name="projectType" required>
              <option>New ERP selection</option>
              <option>Legacy upgrade / migration</option>
              <option>Implementation rescue</option>
              <option>Optimisation / managed support</option>
            </select>
          </label>
          <label>
            Main priority
            <textarea rows="3" name="priorities" placeholder="e.g. reporting, warehouse control, manufacturing planning, multi-entity finance..." required></textarea>
          </label>
          <input class="form-honeypot" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <button class="btn btn-primary" type="submit">Get my shortlist</button>
          <p class="editorial-toolbar">We will email practical next steps and can arrange partner recommendations if useful.</p>
          <p class="form-status" role="status" aria-live="polite"></p>
        </form>
      </aside>
      <div class="hero-latest-row">
        <article class="hero-latest-card">
          <p class="hero-utility-label">Latest guide</p>
          <h2><a href={`/guides/${latestGuides[0]?.slug || ''}/`}>{latestGuides[0]?.title || 'ERP guide'}</a></h2>
          {latestGuides[0] && (
            <>
              <div class="meta-row">
                <p class="meta">Published {formatPublishDate(latestGuides[0].publishedAt)}</p>
                <span class="meta-pill">{estimateReadTimeMinutes(latestGuides[0])} min read</span>
              </div>
              <p>{latestGuides[0].excerpt}</p>
              <ul class="hero-latest-links">
                {latestGuides.slice(1, 2).map((guide) => (
                  <li><a href={`/guides/${guide.slug}/`}>{guide.title}</a></li>
                ))}
                {navGuide && latestGuides.every((guide) => guide.slug !== navGuide.slug) && (
                  <li><a href={`/guides/${navGuide.slug}/`}>NAV / Navision to Business Central migration</a></li>
                )}
              </ul>
            </>
          )}
        </article>
        <article class="hero-latest-card">
          <p class="hero-utility-label">Latest comparison</p>
          <h2><a href={`/compare/${latestComparisons[0]?.slug || ''}/`}>{latestComparisons[0]?.title || 'ERP comparison'}</a></h2>
          {latestComparisons[0] && (
            <>
              <div class="meta-row">
                <p class="meta">Published {formatPublishDate(latestComparisons[0].publishedAt)}</p>
                <span class="meta-pill">{estimateReadTimeMinutes(latestComparisons[0])} min read</span>
              </div>
              <p>{latestComparisons[0].excerpt}</p>
              <ul class="hero-latest-links">
                {latestComparisons.slice(1, 2).map((item) => (
                  <li><a href={`/compare/${item.slug}/`}>{item.title}</a></li>
                ))}
                {featuredComparison && latestComparisons.every((item) => item.slug !== featuredComparison.slug) && (
                  <li><a href={`/compare/${featuredComparison.slug}/`}>{featuredComparison.title}</a></li>
                )}
              </ul>
            </>
          )}
        </article>
        <article class="hero-latest-card">
          <p class="hero-utility-label">Latest insight</p>
          <h2><a href={`/blog/${latestPosts[0]?.slug || ''}/`}>{latestPosts[0]?.title || 'ERP insight'}</a></h2>
          {latestPosts[0] && (
            <>
              <div class="meta-row">
                <p class="meta">Published {formatPublishDate(latestPosts[0].publishedAt)}</p>
                <span class="meta-pill">{estimateReadTimeMinutes(latestPosts[0])} min read</span>
              </div>
              <p>{latestPosts[0].excerpt}</p>
              <ul class="hero-latest-links">
                {latestPosts.slice(1, 3).map((post) => (
                  <li><a href={`/blog/${post.slug}/`}>{post.title}</a></li>
                ))}
              </ul>
            </>
          )}
        </article>
      </div>
    </div>
  </section>

  <section class="section section-frame" id="coverage">
    <div class="section-head">
      <p class="eyebrow">Decision Framework</p>
      <h2>What small and medium business teams should evaluate before choosing an ERP</h2>
      <p class="section-subtle">
        Use these decision tracks to compare options, validate implementation risk, and avoid avoidable project
        mistakes before signing.
      </p>
    </div>
    <div class="split-grid">
      <div class="path-list">
        <article class="path-card">
          <h3>
            <a class="title-with-icon" href="/guides/">
              <span class="tile-icon tile-icon-green" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M7 5h10v14H7z" stroke="currentColor" stroke-width="1.8"/><path d="M9.5 9.5h5M9.5 12.5h5M9.5 15.5h3.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              </span>
              ERP selection guides & checklists
            </a>
          </h3>
          <p>Selection, implementation, upgrade, support, and optimisation playbooks for growing business teams.</p>
          <ul class="mini-list">
            <li>ERP selection framework</li>
            <li>RFP templates and scorecards</li>
            <li>Budget and timeline benchmarks</li>
          </ul>
          <figure class="path-card-visual">
            <img
              src="https://images.pexels.com/photos/3184291/pexels-photo-3184291.jpeg?auto=compress&cs=tinysrgb&w=1200"
              alt="Team reviewing ERP selection notes and decision criteria"
            />
            <figcaption>Shortlist structure, demo discipline, and practical decision controls.</figcaption>
          </figure>
        </article>
        <article class="path-card">
          <h3>
            <a class="title-with-icon" href="/compare/">
              <span class="tile-icon tile-icon-copper" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M5 7h6v10H5zM13 7h6v10h-6z" stroke="currentColor" stroke-width="1.8"/><path d="M8 5v2M16 5v2M8 17v2M16 17v2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
              </span>
              Compare ERP software (fit-first)
            </a>
          </h3>
          <p>Objective pages for major platforms and migration paths, including legacy NAV situations.</p>
          <ul class="mini-list">
            <li>Who it fits / does not fit</li>
            <li>Implementation complexity</li>
            <li>Total cost considerations</li>
          </ul>
          <figure class="path-card-visual">
            <img
              src="https://images.pexels.com/photos/590022/pexels-photo-590022.jpeg?auto=compress&cs=tinysrgb&w=1200"
              alt="Side-by-side software comparison and analytics screens"
            />
            <figcaption>Compare product fit, delivery shape, and likely support overhead.</figcaption>
          </figure>
        </article>
        <article class="path-card">
          <h3>
            <a class="title-with-icon" href="/blog/">
              <span class="tile-icon tile-icon-slate" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none"><path d="M6 6h12v12H6z" stroke="currentColor" stroke-width="1.8"/><path d="M9 10h6M9 13h6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><circle cx="8" cy="17" r="1" fill="currentColor"/><circle cx="12" cy="17" r="1" fill="currentColor"/><circle cx="16" cy="17" r="1" fill="currentColor"/></svg>
              </span>
              Implementation tips, updates & best practices
            </a>
          </h3>
          <p>News, release notes summaries, risk alerts, and best practices for finance/ops/IT stakeholders.</p>
          <ul class="mini-list">
            <li>Version/release updates</li>
            <li>Post-go-live lessons</li>
            <li>Data migration pitfalls</li>
          </ul>
          <figure class="path-card-visual">
            <img
              src="https://images.pexels.com/photos/3183150/pexels-photo-3183150.jpeg?auto=compress&cs=tinysrgb&w=1200"
              alt="Business team discussing implementation lessons and release updates"
            />
            <figcaption>Lessons, release signals, and implementation risks worth watching.</figcaption>
          </figure>
        </article>
      </div>
      <aside class="note-card">
        <p class="eyebrow">Product Update Radar</p>
        <h3>What changed recently across major ERP products</h3>
        <p class="section-subtle compact">
          Use this as a buyer signal, not just product news. New release timing and feature direction can affect shortlist fit,
          upgrade planning, and partner conversations.
        </p>
        <div class="radar-stack">
          <article class="radar-card">
            <div class="radar-head">
              <strong>Microsoft Dynamics 365</strong>
              <span>1 Apr 2026</span>
            </div>
            <p>Microsoft published 2026 release wave 1 timing, with general availability starting on 1 Apr 2026.</p>
            <p class="radar-why"><strong>Why it matters:</strong> useful for Business Central and Dynamics buyers planning sandbox review, upgrade timing, and partner readiness.</p>
            <a href="https://learn.microsoft.com/en-us/dynamics365/get-started/release-schedule" target="_blank" rel="noreferrer">Official release schedule ↗</a>
          </article>
          <article class="radar-card">
            <div class="radar-head">
              <strong>NetSuite 2026.1</strong>
              <span>2026.1 release</span>
            </div>
            <p>NetSuite refreshed its 2026.1 release notes with finance, AI connector, and REST web services updates.</p>
            <p class="radar-why"><strong>Why it matters:</strong> good signal for finance-first teams and buyers with integration-heavy environments.</p>
            <a href="https://docs.oracle.com/en/cloud/saas/netsuite/ns-online-help/chapter_N3944673.html" target="_blank" rel="noreferrer">Official release notes ↗</a>
          </article>
          <article class="radar-card">
            <div class="radar-head">
              <strong>Sage Intacct</strong>
              <span>17 Feb 2026</span>
            </div>
            <p>Sage announced AI-powered close analytics, cash intelligence, connected data access, and import improvements.</p>
            <p class="radar-why"><strong>Why it matters:</strong> relevant for finance-led organisations comparing focused finance depth against broader ERP scope.</p>
            <a href="https://www.sage.com/en-us/news/press-releases/2026/02/sage-intacct-delivers-new-ai-powered-capabilities-to-transform-how-finance-teams-close/" target="_blank" rel="noreferrer">Official product announcement ↗</a>
          </article>
        </div>
        <div class="note-divider"></div>
        <h4>Find your best starting point</h4>
        <ul>
          <li><a href="/guides/">I’m selecting a new ERP</a></li>
          <li><a href={navGuide ? `/guides/${navGuide.slug}/` : '/guides/'}>I’m upgrading NAV / legacy ERP</a></li>
          <li><a href="/compare/">I need to compare platforms</a></li>
          <li><a href="/blog/">I want ongoing ERP updates</a></li>
        </ul>
      </aside>
    </div>
  </section>

  <section class="section section-frame">
    <div class="section-head">
      <p class="eyebrow">Buyer Support</p>
      <h2>Get clearer ERP decisions with less risk and fewer delays</h2>
      <p class="section-subtle">
        Most projects run over budget because teams choose software before validating fit, scope, and implementation
        approach. These checkpoints are designed to help you make a better decision before contracts are signed.
      </p>
    </div>
    <div class="split-grid">
      <article class="card">
        <h3 class="title-with-icon">
          <span class="tile-icon tile-icon-green" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><path d="M4.5 12l4.2 4.2L19.5 5.8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          What’s included in your ERP shortlist guidance
        </h3>
        <ul class="value-list">
          <li>Shortlist guidance based on industry, complexity, and timeline</li>
          <li>Platform fit vs misfit framing before vendor demos</li>
          <li>Implementation partner-fit recommendations (on request)</li>
          <li>Practical planning inputs for budget, timeline, and delivery risk</li>
        </ul>
      </article>
      <article class="card">
        <h3 class="title-with-icon">
          <span class="tile-icon tile-icon-copper" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none"><path d="M6 4h12v16H6z" stroke="currentColor" stroke-width="1.8"/><path d="M9 8h6M9 12h6M9 16h4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          </span>
          Tell us about your ERP project (what we assess)
        </h3>
        <ol class="value-list ordered">
          <li>Company size / revenue band</li>
          <li>Industry and operating model</li>
          <li>Current ERP / legacy system</li>
          <li>Project type (new, upgrade, rescue)</li>
          <li>Target timeline</li>
          <li>Budget range</li>
          <li>Regions / legal entities</li>
          <li>Integration / manufacturing requirements</li>
        </ol>
      </article>
    </div>
  </section>

  <section class="section section-frame">
    <div class="section-head">
      <p class="eyebrow">Comparison Hub</p>
      <h2>Compare ERP software before vendor demos</h2>
      <p class="section-subtle">Use comparison previews and filters to build a confident shortlist before vendor demos.</p>
    </div>
    <div class="home-filterbar">
      <div class="filter-pill">Industry: Distribution / Manufacturing / Services</div>
      <div class="filter-pill">Priority: Finance controls / Ops / Multi-entity</div>
      <a class="btn btn-secondary btn-small" href="/compare/">Open full compare hub</a>
    </div>
    <div class="grid cols-3">
      <article class="card collection-card">
        <p class="eyebrow">Comparison</p>
        <h3>
          <a class="title-with-icon" href={featuredComparison ? `/compare/${featuredComparison.slug}/` : '/compare/'}>
            <span class="tile-icon tile-icon-copper" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M4 8h7v8H4zM13 8h7v8h-7z" stroke="currentColor" stroke-width="1.8"/><path d="M12 6v12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
            </span>
            {featuredComparison?.title || 'Business Central vs NetSuite for SMBs'}
          </a>
        </h3>
        <p>{featuredComparison?.excerpt || 'Practical fit, complexity, and implementation tradeoff comparison for small and medium business buyers.'}</p>
      </article>
      <article class="card collection-card">
        <p class="eyebrow">Migration Path</p>
        <h3>
          <a class="title-with-icon" href={navGuide ? `/guides/${navGuide.slug}/` : '/guides/'}>
            <span class="tile-icon tile-icon-green" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/><path d="M13 8l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/><rect x="4" y="6" width="4" height="12" rx="1.5" stroke="currentColor" stroke-width="1.6"/></svg>
            </span>
            NAV / Navision to Business Central migration
          </a>
        </h3>
        <p>Assessment, upgrade vs reimplementation, data strategy, testing, and cutover planning.</p>
      </article>
      <article class="card collection-card">
        <p class="eyebrow">Partner Fit</p>
        <h3>
          <a class="title-with-icon" href={partnerGuide ? `/guides/${partnerGuide.slug}/` : '/guides/'}>
            <span class="tile-icon tile-icon-slate" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><circle cx="8" cy="9" r="2.5" stroke="currentColor" stroke-width="1.8"/><circle cx="16" cy="9" r="2.5" stroke="currentColor" stroke-width="1.8"/><path d="M5.5 17c.8-2.2 4.2-2.2 5 0M13.5 17c.8-2.2 4.2-2.2 5 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
            </span>
            How to choose an ERP implementation partner
          </a>
        </h3>
        <p>Evaluate delivery quality, scope assumptions, references, and delivery risk.</p>
      </article>
    </div>
  </section>

  <section class="section section-frame" id="blog">
    <div class="section-head">
      <p class="eyebrow">Editorial Engine</p>
      <h2>ERP news, comparisons, and practical buying guidance</h2>
      <p class="section-subtle">Get practical guidance, release analysis, and implementation lessons relevant to growing business teams.</p>
    </div>
    <div class="home-tabs" role="tablist" aria-label="Blog categories">
      <span class="tab-pill is-active">All</span>
      <span class="tab-pill">Selection</span>
      <span class="tab-pill">Implementation</span>
