<script is:inline define:vars={{pollEndpoint, pollBrandAssets}}>
  (() => {
    const poll = document.querySelector('[data-hero-poll]');
    if (!poll) return;

    const inputStatus = poll.querySelector('[data-hero-poll-input-status]');
    const summaryStatus = poll.querySelector('[data-hero-poll-summary-status]');
    const submitButton = poll.querySelector('[data-hero-poll-submit]');
    const inputsNode = poll.querySelector('[data-hero-poll-inputs]');
    const summaryNode = poll.querySelector('[data-hero-poll-summary]');
    const changeVoteButton = poll.querySelector('[data-hero-poll-change]');
    const leaderNode = poll.querySelector('[data-hero-poll-leader]');
    const resultsNode = poll.querySelector('[data-hero-poll-results]');
    const storageKey = 'erp-navigator-current-erp-vote';
    const savedVote = window.localStorage.getItem(storageKey);

    const brandMarkup = (option) => {
      const asset = pollBrandAssets[option] || pollBrandAssets['Spreadsheets / none yet'];
      return `<img class="hero-brand-logo hero-brand-logo-inline" src="${asset}" alt="" aria-hidden="true" />`;
    };

    const setMode = (mode) => {
      const showResults = mode === 'results';
      if (inputsNode) inputsNode.hidden = showResults;
      if (summaryNode) summaryNode.hidden = !showResults;
    };

    const setStatus = (text, mode = 'input') => {
      if (inputStatus) inputStatus.textContent = mode === 'input' ? text : '';
      if (summaryStatus) summaryStatus.textContent = mode === 'results' ? text : '';
    };

    const setBusy = (busy) => {
      poll.classList.toggle('is-busy', busy);
      if (submitButton) {
        if (!submitButton.dataset.label) submitButton.dataset.label = submitButton.textContent || 'Vote';
        submitButton.disabled = busy;
        submitButton.textContent = busy ? 'Saving...' : submitButton.dataset.label;
      }
    };

    const renderResults = (results, selectedOption) => {
      if (!resultsNode || !results || !Array.isArray(results.options)) return;
      const leader = results.options
        .slice()
        .sort((a, b) => (b.votes - a.votes) || a.option.localeCompare(b.option))[0];

      if (leaderNode && leader && results.total > 0) {
        leaderNode.hidden = false;
        leaderNode.innerHTML = `
          <span class="hero-poll-leader-kicker">Current leader</span>
          <span class="hero-poll-leader-main">${brandMarkup(leader.option)}<strong>${leader.option}</strong></span>
          <span class="hero-poll-leader-meta">${leader.percent}% · ${leader.votes} vote${leader.votes === 1 ? '' : 's'}</span>
        `;
      } else if (leaderNode) {
        leaderNode.hidden = true;
        leaderNode.innerHTML = '';
      }

      resultsNode.hidden = false;
      resultsNode.innerHTML = results.options
        .map((entry) => {
          const active = selectedOption && entry.option === selectedOption ? ' is-selected' : '';
          return `
            <div class="hero-poll-result${active}">
              <div class="hero-poll-result-row">
                <strong>${brandMarkup(entry.option)} ${entry.option}</strong>
                <span>${entry.percent}%</span>
              </div>
              <div class="hero-poll-bar"><span style="width: ${entry.percent}%"></span></div>
              <small>${entry.votes} vote${entry.votes === 1 ? '' : 's'}</small>
            </div>
          `;
        })
        .join('') + `<p class="hero-poll-total">Total votes: ${results.total || 0}</p>`;
    };

    const loadResults = async () => {
      try {
        const response = await fetch(pollEndpoint);
        const data = await response.json();
        if (response.ok && data.ok && data.results) {
          renderResults(data.results, window.localStorage.getItem(storageKey));
        }
      } catch {}
    };

    if (savedVote) {
      const selected = poll.querySelector(`input[value="${CSS.escape(savedVote)}"]`);
      if (selected) selected.checked = true;
      setStatus(`Your saved vote: ${savedVote}`, 'results');
      setMode('results');
    } else {
      setMode('input');
    }

    loadResults();

    if (changeVoteButton) {
      changeVoteButton.addEventListener('click', () => {
        setMode('input');
        setStatus('', 'input');
      });
    }

    poll.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (poll.classList.contains('is-busy')) return;

      const selected = poll.querySelector('input[name="currentErp"]:checked');
      if (!selected) {
        setStatus('Choose an option first.', 'input');
        return;
      }

      try {
        setBusy(true);
        setStatus('Saving your vote...', 'input');
        const response = await fetch(pollEndpoint, {
          method: 'POST',
          headers: {'Content-Type': 'application/json'},
          body: JSON.stringify({
            type: 'poll',
            option: selected.value,
            page: window.location.href,
            submittedAt: new Date().toISOString(),
          }),
        });
        const data = await response.json();
        if (!response.ok || !data.ok) throw new Error(data.error || 'Poll vote failed');

        window.localStorage.setItem(storageKey, selected.value);
        setMode('results');
        setStatus(`Saved: ${selected.value}. Thanks for sharing.`, 'results');
        if (data.results) renderResults(data.results, selected.value);
      } catch (error) {
        setStatus('Vote failed. Please try again.', 'input');
        setBusy(false);
        return;
      }

      setBusy(false);

      if (window.gtag) {
        window.gtag('event', 'hero_poll_vote', {
          poll_name: 'current_erp',
          option: selected.value,
        });
      }
    });
  })();
</script>

<script is:inline define:vars={{assessmentEndpoint, newsletterEndpoint}}>
  const asText = (value) => (typeof value === 'string' ? value.trim() : '');

  async function postPayload(endpoint, payload) {
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {'Content-Type': 'application/json'},
      body: JSON.stringify(payload),
    });
    if (!response.ok) throw new Error(`Request failed (${response.status})`);
    return response;
  }

  function setStatus(form, text, isError = false) {
    const node = form.querySelector('.form-status');
    if (!node) return;
    node.textContent = text;
    node.dataset.state = isError ? 'error' : 'success';
  }

  function setBusy(form, busy) {
    const submit = form.querySelector('button[type="submit"]');
    if (!submit) return;
    if (!submit.dataset.label) submit.dataset.label = submit.textContent || 'Submit';
    submit.disabled = busy;
    submit.textContent = busy ? 'Submitting...' : submit.dataset.label;
  }

  function setupAssessment() {
    const forms = document.querySelectorAll('.js-lead-form');
    if (!forms.length) return;
    forms.forEach((form) => {
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const endpoint = form.dataset.endpoint || assessmentEndpoint;
        if (!endpoint) {
          setStatus(form, 'Submission endpoint is not configured yet.', true);
          return;
        }
        const data = new FormData(form);
        if (asText(data.get('website'))) return;

        const payload = {
          type: 'assessment',
          email: asText(data.get('email')),
          phoneCountryCode: asText(data.get('phoneCountryCode')),
          phoneNumber: asText(data.get('phoneNumber')).replace(/[^\d()+\-\s]/g, ''),
          companySize: asText(data.get('companySize')),
          projectType: asText(data.get('projectType')),
          priorities: asText(data.get('priorities')),
          page: window.location.href,
          submittedAt: new Date().toISOString(),
        };

        if (!payload.email || !payload.phoneCountryCode || !payload.phoneNumber || !payload.companySize || !payload.projectType || !payload.priorities) {
          setStatus(form, 'Please complete all fields before submitting.', true);
          return;
        }

        try {
          setBusy(form, true);
          await postPayload(endpoint, payload);
          form.reset();
          const countrySelect = form.querySelector('select[name="phoneCountryCode"]');
          if (countrySelect) countrySelect.value = '+61';
          setStatus(form, 'Thanks. We received your request and will respond shortly.');
        } catch (error) {
          setStatus(form, 'Submission failed. Please try again in a moment.', true);
        } finally {
          setBusy(form, false);
        }
      });
    });
  }

  function setupNewsletter() {
    const form = document.querySelector('.js-newsletter-form');
    if (!form) return;
    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const endpoint = form.dataset.endpoint || newsletterEndpoint;
      if (!endpoint) {
        setStatus(form, 'Newsletter endpoint is not configured yet.', true);
        return;
      }
      const data = new FormData(form);
      if (asText(data.get('website'))) return;

      const payload = {
        type: 'newsletter',
        email: asText(data.get('email')),
        page: window.location.href,
        submittedAt: new Date().toISOString(),
      };

      if (!payload.email) {
        setStatus(form, 'Please enter your work email.', true);
        return;
      }

      try {
        setBusy(form, true);
        await postPayload(endpoint, payload);
        form.reset();
        setStatus(form, 'Subscribed. You will receive the next ERP brief.');
      } catch (error) {
        setStatus(form, 'Subscription failed. Please try again.', true);
      } finally {
        setBusy(form, false);
      }
    });
  }

  setupAssessment();
  setupNewsletter();
</script>
