---
import SiteLayout from '../../layouts/SiteLayout.astro'
import PageVisual from '../../components/PageVisual.astro'
import {pageVisuals} from '../../lib/pageVisuals'
import {buildBreadcrumbSchema, getListPageMeta} from '../../lib/seo'
import {getComparisons} from '../../lib/sanity'

const items = await getComparisons()
const meta = getListPageMeta('compare')
const breadcrumbSchema = buildBreadcrumbSchema([
  {name: 'Home', path: '/'},
  {name: 'Compare', path: '/compare/'},
])
---

<SiteLayout
  title={`${meta.metaTitle} | ERP Search`}
  description={meta.metaDescription}
  canonicalPath="/compare/"
  ogImage={pageVisuals.comparisons.src}
  jsonLd={breadcrumbSchema}
>
  <div class="page-kicker">
    <p class="eyebrow">Comparisons</p>
    <p class="editorial-toolbar">{items.length} published comparison{items.length === 1 ? '' : 's'}</p>
  </div>
  <h1 class="page-title">ERP Software Comparisons for SMBs</h1>
  <p class="section-subtle">Compare ERP platforms by fit, complexity, costs, and implementation trade-offs for growing business buyers.</p>
  <PageVisual
    src={pageVisuals.comparisons.src}
    alt={pageVisuals.comparisons.alt}
    caption="Compare platforms by operational fit, timeline risk, and total ownership model."
  />
  <div class="editorial-list section">
    {items.map((item) => (
      <article class="editorial-item">
        <h2><a href={`/compare/${item.slug}/`}>{item.title}</a></h2>
        <p class="meta">
          {item.leftProduct} vs {item.rightProduct} • Updated {new Date(item.updatedAt || item.publishedAt).toLocaleDateString()}
        </p>
        <p>{item.excerpt}</p>
        {item.bestFor && item.bestFor.length > 0 && (
          <ul>
            {item.bestFor.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        )}
      </article>
    ))}
  </div>
</SiteLayout>
