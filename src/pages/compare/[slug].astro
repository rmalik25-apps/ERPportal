---
import SiteLayout from '../../layouts/SiteLayout.astro'
import PageVisual from '../../components/PageVisual.astro'
import {getComparisonVisual} from '../../lib/pageVisuals'
import {blocksToPlainParagraphs, blocksToRichContent} from '../../lib/portableText'
import {estimateReadTimeMinutes, formatPublishDate} from '../../lib/contentMeta'
import {getRelatedComparisonLinks} from '../../lib/relatedContent'
import {buildBreadcrumbSchema, extractFaqSchema, getDocMeta} from '../../lib/seo'
import {getComparisonBySlug, getComparisons} from '../../lib/sanity'

export async function getStaticPaths() {
  const items = await getComparisons()
  return items.map((item) => ({params: {slug: item.slug}}))
}

const {slug} = Astro.params
const item = slug ? await getComparisonBySlug(slug) : undefined

if (!item) {
  return Astro.redirect('/compare/')
}

const paragraphs = blocksToPlainParagraphs(item.body)
const content = blocksToRichContent(item.body)
const readTime = estimateReadTimeMinutes(item)
const canonicalPath = `/compare/${item.slug}/`
const visual = getComparisonVisual(item.slug)
const relatedLinks = getRelatedComparisonLinks(item.slug)
const seoMeta = getDocMeta(item)
const breadcrumbSchema = buildBreadcrumbSchema([
  {name: 'Home', path: '/'},
  {name: 'Compare', path: '/compare/'},
  {name: item.title, path: canonicalPath},
])
const faqSchema = extractFaqSchema(item.body)
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: seoMeta.metaTitle,
  description: seoMeta.metaDescription,
  datePublished: item.publishedAt,
  dateModified: item.updatedAt || item.publishedAt,
  image: [visual.src],
  articleSection: 'ERP comparison',
  mainEntityOfPage: {'@type': 'WebPage', '@id': canonicalPath},
}
const pageSchemas = faqSchema ? [breadcrumbSchema, articleSchema, faqSchema] : [breadcrumbSchema, articleSchema]
---

<SiteLayout
  title={`${seoMeta.metaTitle} | ERP Search`}
  description={seoMeta.metaDescription}
  canonicalPath={canonicalPath}
  ogImage={visual.src}
  ogType="article"
  noIndex={Boolean(item.seo?.noIndex)}
  jsonLd={pageSchemas}
>
  <div class="doc-layout">
    <article class="doc-main">
      <p class="eyebrow">Comparison</p>
      <h1>{item.title}</h1>
      <div class="meta-row">
        <p class="meta">{item.leftProduct} vs {item.rightProduct} • Published {formatPublishDate(item.publishedAt)}</p>
        <span class="meta-pill">{readTime} min read</span>
        {item.updatedAt && <span class="meta-pill">Updated {formatPublishDate(item.updatedAt)}</span>}
      </div>
      <PageVisual
        src={visual.src}
        alt={visual.alt}
        caption={visual.caption}
      />
      <section class="summary-box" aria-label="Comparison summary">
        <h2>At a glance</h2>
        <dl>
          <dt>Left</dt>
          <dd>{item.leftProduct}</dd>
          <dt>Right</dt>
          <dd>{item.rightProduct}</dd>
          <dt>Intent</dt>
          <dd>Shortlist and fit analysis</dd>
        </dl>
      </section>
      <p class="lead">{item.excerpt}</p>
      {content.length ? (
        content.map((block) =>
          block.type === 'heading' ? (
            <h2>{block.text}</h2>
          ) : block.type === 'list' ? (
            <ul>
              {block.items.map((entry) => (
                <li>{entry}</li>
              ))}
            </ul>
          ) : (
            <p>{block.text}</p>
          ),
        )
      ) : (
        <p class="empty">No content body yet.</p>
      )}
    </article>
    <aside class="doc-side">
      <section class="card">
        <h2>Best for summary</h2>
        {item.bestFor?.length ? (
          <ul>
            {item.bestFor.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        ) : (
          <p class="empty">Add `bestFor` bullets in Sanity.</p>
        )}
        <p><a class="link-arrow" href="/guides/">See related guides →</a></p>
      </section>
      {relatedLinks.length ? (
        <section class="card">
          <h2>Related reading</h2>
          <ul>
            {relatedLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </section>
      ) : null}
    </aside>
  </div>
</SiteLayout>
