---
import SiteLayout from '../../layouts/SiteLayout.astro'
import PageVisual from '../../components/PageVisual.astro'
import {pageVisuals} from '../../lib/pageVisuals'
import {buildBreadcrumbSchema, getListPageMeta} from '../../lib/seo'
import {getGuides} from '../../lib/sanity'

const guides = await getGuides()
const meta = getListPageMeta('guides')
const breadcrumbSchema = buildBreadcrumbSchema([
  {name: 'Home', path: '/'},
  {name: 'Guides', path: '/guides/'},
])
---

<SiteLayout
  title={`${meta.metaTitle} | ERP Search`}
  description={meta.metaDescription}
  canonicalPath="/guides/"
  ogImage={pageVisuals.guides.src}
  jsonLd={breadcrumbSchema}
>
  <div class="page-kicker">
    <p class="eyebrow">Guides</p>
    <p class="editorial-toolbar">{guides.length} published guide{guides.length === 1 ? '' : 's'}</p>
  </div>
  <h1 class="page-title">ERP Guides for SMBs</h1>
  <p class="section-subtle">ERP selection, migration, implementation, and change-management guides for growing business teams.</p>
  <PageVisual
    src={pageVisuals.guides.src}
    alt={pageVisuals.guides.alt}
    caption="Practical implementation guidance for growing teams."
  />
  <div class="editorial-list section">
    {guides.map((guide) => (
      <article class="editorial-item">
        <p class="eyebrow">{guide.intent || 'Guide'}</p>
        <h2><a href={`/guides/${guide.slug}/`}>{guide.title}</a></h2>
        <p class="meta">Updated {new Date(guide.updatedAt || guide.publishedAt).toLocaleDateString()}</p>
        <p>{guide.excerpt}</p>
      </article>
    ))}
  </div>
</SiteLayout>
